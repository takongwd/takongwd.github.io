# Takong Wedding Laos - Environment Variables Example
# Duplicate this file as '.env.local' or '.env' and populate with your Supabase credentials.
# When populated, the application will automatically switch from Mock Mode to Supabase Mode.

# Supabase URL (found in project settings -> API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (found in project settings -> API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
